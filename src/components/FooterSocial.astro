---
import { Icon } from 'astro-icon/components'
import { SOCIAL_LINKS } from '../consts'
---

<nav>
  <ul class="flex items-center justify-center gap-4">
    {
      SOCIAL_LINKS.map((i) => (
        <li>
          <a {...i}>
            <Icon name={i.icon} size={28} />
            <span class="sr-only">{i.name}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>
